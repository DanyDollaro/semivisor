#!/usr/bin/env bash
set -euo pipefail

SEMIVISOR_SYS_FILE="./build/semivisor.sys"
SEMIVISOR_EXE_FILE="./build/semivisor.exe"
CLIENT_FILE="./build/client.exe"
NASM_SRC_DIR="./nasm"
NASM_OBJ_DIR="./nasm/objs"
NASM_LIB_DIR="./static-libs/windows-x64/nasm/"

log()  { echo -e "\e[34m[*]\e[0m $*"; }
ok()   { echo -e "\e[32m[+]\e[0m $*"; }
die()  { echo -e "\e[31m[-]\e[0m $*" >&2; exit 1; }

# 1. Build nasm files
log "Building NASM files..."
mkdir -p "$NASM_OBJ_DIR" "$NASM_LIB_DIR"
for asm_file in "$NASM_SRC_DIR"/*.asm; do
    [[ -e "$asm_file" ]] || die "No .asm files found in $NASM_SRC_DIR"
    base=$(basename "$asm_file" .asm)
    obj_file="$NASM_OBJ_DIR/${base}.obj"
    lib_file="$NASM_LIB_DIR/${base}.lib"
    log "  Assembling $asm_file → $obj_file"
    nasm -f win64 "$asm_file" -o "$obj_file" || die "nasm failed for $asm_file"
    log "  Archiving  $obj_file → $lib_file"
    llvm-ar rcs "$lib_file" "$obj_file" || die "llvm-ar failed for $obj_file"
    ok "  ${base}: assembled and archived"
done
ok "All NASM files built"

# 2. Build semivisor
log "Building semivisor..."
c3c build semivisor || die "c3c build semivisor failed"
[[ -f "$SEMIVISOR_EXE_FILE" ]] || die "Expected output not found: $SEMIVISOR_EXE_FILE"
ok "Semivisor build succeeded → $SEMIVISOR_EXE_FILE"

# 3. Convert to .sys
log "Converting to driver image..."
./scripts/cvtdrv "$SEMIVISOR_EXE_FILE" || die "cvtdrv failed"
[[ -f "$SEMIVISOR_SYS_FILE" ]] || die "Expected output not found: $SEMIVISOR_SYS_FILE"
ok "Semivisor conversion succeeded → $SEMIVISOR_SYS_FILE"

# 4. Build the client
log "Building client..."
c3c build client || die "c3c build client failed"
[[ -f "$CLIENT_FILE" ]] || die "Expected output not found: $CLIENT_FILE"
ok "Client build succeeded → $CLIENT_FILE"

